;;; -*- mode: lisp-interaction; -*-
fundamental-mode
(today (format-time-string "%D")
			 :ann "today's date"
			 :doc "insert today's date")
(todayy (format-time-string "%A %B %d"))
(iso (format-time-string "%FT%T%z")
			:ann "the date in iso 8601 format")

org-mode
(\\equ "\\begin{equation}\n" r n "\\end{equation}")
(\\arr "\\begin{array}{lcr}\n" r n "\\end{array}")
(\\arrl "\\begin{array}{l}\n" r n "\\end{array}")
(\\arrr "\\begin{array}{r}\n" r n "\\end{array}")
(\\box "\\boxed{\n" r n "}")
(\\ce "\\ce{" r "}")
(\\dce "$\\ce{" r "}$")
(img "[[" p "][" p "]]")
(\\def "\\begin{equation}\\boxed{\n\\textbf{Definition}\\text{: " r "}" n "}\\end{equation}")
(\\fbox "$\\fbox{\\textbf{Definition}" r "}$")
(\\tc "\\textcolor{" (p "color: ") "}{\\text{" r "}}")
(\\dtc "$\\textcolor{" (p "color: ") "}{" r "}$")
(\\note "\\textcolor{red}{note}: " r)
(\\dnote "$\\textcolor{red}{note}$: " r)
(\\begin "\\begin{" (p "" whatisit) "}\n" r "\n\\end{" (s whatisit) "}")
(\\thm "$\\textcolor{red}{Theorem:}\\text{" p "}$\n\\begin{array}{l}\n" r "\n\\end{array}")
(\\exp "\\textcolor{blue}{\\text{" r "}}")
(\\pad "\\phantom{()()()}")
(\\pic "\\textcolor{red}{\\text{pic needed}}")
(\\dpic "$\\textcolor{red}{\\text{pic needed}}$")
(\( "\\left(" r "\\right")
(| "\\left|" r "\\right|")
(\\sum "\\displaystyle\\sum_{" p "}^" r)
(\\lim "\\lim\\limits_{" p "}" r)
(\[ "\\left[" r "\\right")
(sp "\\text{ }")
(\\x "\\xcancel{" r "}")

c-mode
(gtk "/* -*- compile-command: \"gcc $(pkg-config --cflags gtk4) -o front_end front_end.c $(pkg-config --libs gtk4)\"; -*- */
#include <gtk/gtk.h>
")

java-mode
(class "public class " p " {" n r n "}")
(main "public static void main(String[] args) {" n r n "}")

c-mode
(glut "/* -*- compile-command: \"gcc test.c -lGL -lGLU -lglut\"; -*- */
#include <GL/glut.h>\n")
(stdio "#include <stdio.h>\n")
